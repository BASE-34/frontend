# ── API Backend ──────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:4000

# ── Cloudflare Turnstile ──────────────────────────────────────────────────────
# Server-side toggle (read by +page.server.ts via $env/dynamic/private)
ENABLE_TURNSTILE=false

# Client-side toggle (read by Turnstile.svelte widget)
PUBLIC_ENABLE_TURNSTILE=false

# Test keys — safe to commit. Widget always passes, siteverify always fails.
# Replace with real keys from https://dash.cloudflare.com when going live.
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
